generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DraftMode {
  SIMULATED
  ARENA
}

enum DraftStatus {
  PENDING
  COMPLETED
}

enum TeamSide {
  A
  B
}

enum ScrimFormat {
  STANDARD
  META
  LIBRE
}

enum ScrimFakePreset {
  DEFAULT
  NOHEALERS
  NOTANKS
  NODPS
  ONEHEALER
}

enum ManualRegistrationType {
  HEALER
  TANK
}

model Player {
  id           Int                @id @default(autoincrement())
  userId       String             @unique
  username     String
  mmr          Int                @default(950)
  partidas     Int                @default(0)
  victorias    Int                @default(0)
  isFake       Boolean            @default(false)
  isHealer     Boolean            @default(false)
  fakeRoles    String[]           @default([])
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  registration ArenaRegistration?
  draftPlayers DraftPlayer[]
}

model ArenaRegistration {
  id           Int      @id @default(autoincrement())
  playerId     Int      @unique
  registeredAt DateTime @default(now())
  player       Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model Draft {
  id               Int         @id @default(autoincrement())
  mode             DraftMode
  status           DraftStatus @default(PENDING)
  teamAAvgMmr      Int
  teamBAvgMmr      Int
  teamAProbability Float
  teamBProbability Float
  winner           TeamSide?
  createdAt        DateTime    @default(now())
  completedAt      DateTime?
  players          DraftPlayer[]
}

model DraftPlayer {
  id       Int      @id @default(autoincrement())
  draftId  Int
  playerId Int
  team     TeamSide
  position Int
  draft    Draft    @relation(fields: [draftId], references: [id], onDelete: Cascade)
  player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([draftId, playerId])
}

model AppConfig {
  id                   Int       @id @default(1)
  allowedArenaRoleIds  String[]  @default([])
  allowedArenaUserIds  String[]  @default([])
  publicCommands       String[]  @default([])
  scrimFormat          ScrimFormat @default(STANDARD)
  scrimMaxPlayers      Int       @default(10)
  scrimFakePreset      ScrimFakePreset @default(DEFAULT)
  allowAuxHealerSignup Boolean   @default(false)
  allowAuxTankSignup   Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model ManualRegistration {
  userId    String
  role      ManualRegistrationType
  createdAt DateTime @default(now())

  @@id([userId, role])
  @@index([role])
}

model CommunityRegistrationBoard {
  id              Int                          @id @default(autoincrement())
  guildId         String
  channelId       String
  createdByUserId String
  isClosed        Boolean                      @default(false)
  createdAt       DateTime                     @default(now())
  closedAt        DateTime?
  batches         CommunityRegistrationBatch[]
  entries         CommunityRegistrationEntry[]
}

model CommunityRegistrationBatch {
  id          Int                        @id @default(autoincrement())
  boardId     Int
  batchNumber Int
  channelId   String
  messageId   String                     @unique
  createdAt   DateTime                   @default(now())
  board       CommunityRegistrationBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@unique([boardId, batchNumber])
}

model CommunityRegistrationEntry {
  id            Int                        @id @default(autoincrement())
  boardId       Int
  batchNumber   Int
  userId        String                     @unique
  username      String
  arena         Boolean                    @default(false)
  scrim         Boolean                    @default(false)
  crystalLeague Boolean                    @default(false)
  crystal20v20  Boolean                    @default(false)
  registeredAt  DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  board         CommunityRegistrationBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId, batchNumber])
}
